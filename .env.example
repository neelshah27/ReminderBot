# ── Discord ──────────────────────────────────────────────────────
# 1. Go to https://discord.com/developers/applications
# 2. Create an app → Bot → copy token
# 3. Enable "MESSAGE CONTENT INTENT" under Bot settings
# 4. Invite bot to your server with Send Messages permission
DISCORD_TOKEN=your-bot-token-here
DISCORD_CHANNEL_ID=123456789012345678

# ── Twilio (for SMS) ────────────────────────────────────────────
# 1. Sign up free at https://www.twilio.com
# 2. Get your Account SID, Auth Token, and a phone number
TWILIO_ACCOUNT_SID=your-sid-here
TWILIO_AUTH_TOKEN=your-auth-here
TWILIO_FROM_NUMBER=+1234567890

# ── Phone numbers to text (comma-separated) ─────────────────────
PHONE_NUMBERS=+1234567890,+0987654321
